# IMPORTANT: After rotating your GitHub and Discord OAuth client IDs in their
# respective developer dashboards, paste the new values into .env (never .env.example).
# The old IDs that were committed should be considered compromised — rotate them.
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here
VITE_GITHUB_CLIENT_ID=your_github_oauth_client_id_here
VITE_DISCORD_CLIENT_ID=your_discord_oauth_client_id_here
VITE_FACEBOOK_CLIENT_ID=your_facebook_client_id_here
