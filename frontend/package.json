{
  "name": "ourguided-frontend",
  "version": "2.0.0",
  "private": true,
  "dependencies": {
    "axios": "^1.6.5",
    "date-fns": "^3.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.4.1",
    "react-icons": "^5.0.1",
    "react-router-dom": "^6.30.3",
    "react-textarea-autosize": "^8.5.3"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.4",
    "puppeteer": "^24.40.0",
    "react-snap": "^1.23.0",
    "vite": "^7.3.1"
  },
  "reactSnap": {
    "source": "dist",
    "inlineCss": true,
    "skipThirdPartyRequests": true,
    "puppeteerArgs": ["--no-sandbox", "--disable-setuid-sandbox", "--disable-dev-shm-usage"],
    "puppeteerWaitForTimeout": 3000,
    "include": [
      "/",
      "/login",
      "/register",
      "/explore",
      "/feed"
    ],
    "userAgent": "ReactSnap"
  }
}
