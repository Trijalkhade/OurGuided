{
  "name": "ourguided-frontend",
  "version": "2.0.0",
  "private": true,
  "dependencies": {
    "axios": "^1.6.5",
    "date-fns": "^3.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.4.1",
    "react-icons": "^5.0.1",
    "react-router-dom": "^6.30.3",
    "react-textarea-autosize": "^8.5.3",
    "socket.io-client": "^4.8.3"
  },
  "scripts": {
    "dev": "vite",
    "optimize": "node scripts/optimize-images.mjs",
    "build": "node scripts/optimize-images.mjs && vite build",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.4",
    "puppeteer": "^24.40.0",
    "react-snap": "^1.13.1",
    "sharp": "^0.33.5",
    "vite": "^7.3.1",
    "vite-plugin-compression": "^0.5.1"
  },
  "reactSnap": {
    "source": "dist",
    "inlineCss": true,
    "skipThirdPartyRequests": true,
    "puppeteerArgs": [
      "--no-sandbox",
      "--disable-setuid-sandbox",
      "--disable-dev-shm-usage"
    ],
    "puppeteerWaitForTimeout": 3000,
    "include": [
      "/",
      "/login",
      "/register",
      "/browse",
      "/explore",
      "/feed",
      "/leaderboard",
      "/connections",
      "/quizzes",
      "/playlists"
    ],
    "userAgent": "ReactSnap"
  },
  "overrides": {
    "react-snap": {
      "html-minifier": "npm:html-minifier-terser@^7.2.0",
      "minimalcss": {
        "cheerio": "^1.0.0-rc.12",
        "css-select": "^4.3.0"
      },
      "sourcemapped-stacktrace-node": {
        "isomorphic-fetch": {
          "node-fetch": "^2.7.0"
        }
      },
      "express": "^4.21.2"
    },
    "minimist": "^1.2.8",
    "body-parser": "^1.20.3",
    "cookie": "^0.7.2",
    "serve-static": "^1.16.2",
    "nth-check": "^2.1.1",
    "send": "^0.19.0",
    "qs": "^6.14.1",
    "path-to-regexp": "^0.1.12"
  }
}